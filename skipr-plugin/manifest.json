{
    "manifest_version": 3,
    "name": "Skipr",
    "version": "1.9",
    "description": "Skips Video Content on Youtube Videos",
    "browser_specific_settings": {
        "gecko": {
            "id": "id@skipr-youtube",
            "strict_min_version": "109.0"
        }
    },
    "icons": {
        "16": "icons/icon-16.png",
        "32": "icons/icon-32.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },
    "permissions": [
        "storage",
        "tabs"
    ],
    "host_permissions": [
        "https://skipr-plugin.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_icon": {
            "16": "icons/icon-16.png",
            "32": "icons/icon-32.png",
            "48": "icons/icon-48.png"
        },
        "default_popup": "popup.html",
        "default_title": "Skipr"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.youtube.com/watch*",
                "https://youtube.com/watch*"
            ],
            "js": [
                "ext.js",
                "config.js",
                "notifications.js",
                "processor.js"
            ]
        }
    ]
}